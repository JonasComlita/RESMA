{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "paths": {
            "*": [
                "./*"
            ],
            "@resma/shared": [
                "../packages/shared"
            ]
        },
        "lib": [
            "ES2022"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "../node_modules/@types"
        ],
        "types": [
            "node",
            "bcryptjs",
            "cors",
            "express",
            "jsonwebtoken",
            "morgan",
            "bun"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
