generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  VIEWER
  CREATOR
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model User {
  id                         String            @id @default(uuid())
  anonymousId                String            @unique @default(uuid())
  passwordHash               String
  recoveryCodeHash           String?           @unique
  userType                   UserType          @default(VIEWER)
  subscriptionTier           SubscriptionTier  @default(FREE)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  preferences                Bytes?            // MessagePack + Zstandard compressed

  // Privacy settings
  contributeToCreatorInsights Boolean           @default(true)

  feedSnapshots              FeedSnapshot[]
  ingestEvents               IngestEvent[]
  creatorProfile             Creator?
  apiKeys                    ApiKey[]

  @@map("users")
}

model Creator {
  id               String            @id @default(uuid())
  userId           String            @unique
  displayName      String?
  avatarUrl        String?
  verified         Boolean           @default(false)
  verifiedAt       DateTime?
  claimedAt        DateTime          @default(now())
  
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformAccounts PlatformAccount[]
  reachStats       CreatorReach[]

  @@map("creators")
}

model PlatformAccount {
  id                String   @id @default(uuid())
  creatorId         String   @map("creator_id")
  platform          String
  platformAccountId String?  @map("platform_account_id")
  platformHandle    String   @map("platform_handle")
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  creator           Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@unique([platform, platformHandle])
  @@unique([platform, platformAccountId])
  @@map("platform_accounts")
}

model CreatorReach {
  id               String    @id @default(uuid())
  creatorId        String
  platform         String    @default("tiktok")
  date             DateTime  @db.Date
  uniqueViewers    Int       @default(0)
  totalImpressions Int       @default(0)
  likesCount       Int?
  commentsCount    Int?
  sharesCount      Int?
  audienceProfile  Bytes?    // MessagePack + Zstandard compressed
  
  creator          Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform, date])
  @@index([creatorId, platform])
  @@map("creator_reach")
}

model FeedSnapshot {
  id             String     @id @default(uuid())
  userId         String
  capturedAt     DateTime   @default(now())
  platform       String     @default("tiktok")
  itemCount      Int        @default(0)
  avgWatchTime   Float?
  sessionMetadata Bytes?    // MessagePack + Zstandard compressed
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItems     FeedItem[]
  ingestEvent   IngestEvent?

  @@index([userId])
  @@index([capturedAt])
  @@map("feed_snapshots")
}

model IngestEvent {
  id         String        @id @default(uuid())
  userId     String
  uploadId   String
  snapshotId String?       @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot   FeedSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([userId, uploadId])
  @@index([userId])
  @@map("ingest_events")
}

model FeedItem {
  id               String       @id @default(uuid())
  snapshotId       String
  videoId          String
  creatorId        String?
  creatorHandle    String?
  positionInFeed   Int
  caption          String?
  musicId          String?
  musicTitle       String?
  likesCount       Int?
  commentsCount    Int?
  sharesCount      Int?
  engagementMetrics Bytes?  // MessagePack + Zstandard compressed
  contentTags      String[]
  contentCategories String[]    // Detected categories for "why am I seeing this"
  watchDuration    Float?
  interacted       Boolean      @default(false)
  interactionType  String?
  
  snapshot         FeedSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([videoId])
  @@index([creatorHandle])
  @@index([likesCount])
  @@index([commentsCount])
  @@index([sharesCount])
  @@map("feed_items")
}

model ApiKey {
  id             String            @id @default(uuid())
  userId         String
  name           String
  lookupId       String            @unique
  keyPrefix      String
  keyHash        String            @unique
  status         ApiKeyStatus      @default(ACTIVE)
  scopes         String[]
  dailyQuota     Int               @default(500)
  monthlyQuota   Int               @default(10000)
  totalRequests  Int               @default(0)
  lastUsedAt     DateTime?
  lastUsedIp     String?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDaily     ApiKeyUsageDaily[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("api_keys")
}

model ApiKeyUsageDaily {
  id            String   @id @default(uuid())
  apiKeyId      String
  usageDate     DateTime @db.Date
  routeKey      String
  requestCount  Int      @default(0)
  successCount  Int      @default(0)
  errorCount    Int      @default(0)
  lastRequestAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apiKey        ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, usageDate, routeKey])
  @@index([apiKeyId, usageDate])
  @@map("api_key_usage_daily")
}
