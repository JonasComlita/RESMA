generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  VIEWER
  CREATOR
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum AccessPackage {
  CONTRIBUTOR_FREE
  CREATOR_PRO
  AGENCY_PILOT
  ENTERPRISE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum AgencyReportType {
  AUDIENCE_OPPORTUNITY_BRIEF
  COMPETITOR_REACH_SNAPSHOT
  RECOMMENDATION_GAP_REPORT
}

enum AgencyReportShareStatus {
  ACTIVE
  REVOKED
}

enum AgencyReportAuditEventType {
  PRESET_CREATED
  PRESET_UPDATED
  PRESET_ARCHIVED
  RUN_GENERATED
  EXPORT_ACCESSED
  SHARE_CREATED
  SHARE_VIEWED
  SHARE_REVOKED
}

model User {
  id                         String            @id @default(uuid())
  anonymousId                String            @unique @default(uuid())
  passwordHash               String
  recoveryCodeHash           String?           @unique
  recoveryCodeLookupHash     String?           @unique
  recoveryCodeExpiresAt      DateTime?
  userType                   UserType          @default(VIEWER)
  subscriptionTier           SubscriptionTier  @default(FREE)
  accessPackage              AccessPackage     @default(CONTRIBUTOR_FREE)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  preferences                Bytes?            // MessagePack + Zstandard compressed

  // Privacy settings
  contributeToCreatorInsights Boolean           @default(true)

  feedSnapshots              FeedSnapshot[]
  ingestEvents               IngestEvent[]
  creatorProfile             Creator?
  apiKeys                    ApiKey[]
  reportPresets              AgencyReportPreset[]
  reportRuns                 AgencyReportRun[]
  reportAuditEvents          AgencyReportAuditEvent[]

  @@map("users")
}

model Creator {
  id               String            @id @default(uuid())
  userId           String            @unique
  displayName      String?
  avatarUrl        String?
  verified         Boolean           @default(false)
  verifiedAt       DateTime?
  claimedAt        DateTime          @default(now())
  
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformAccounts PlatformAccount[]
  reachStats       CreatorReach[]

  @@map("creators")
}

model PlatformAccount {
  id                String   @id @default(uuid())
  creatorId         String   @map("creator_id")
  platform          String
  platformAccountId String?  @map("platform_account_id")
  platformHandle    String   @map("platform_handle")
  verified          Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  creator           Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@unique([platform, platformHandle])
  @@unique([platform, platformAccountId])
  @@map("platform_accounts")
}

model CreatorReach {
  id               String    @id @default(uuid())
  creatorId        String
  platform         String    @default("tiktok")
  date             DateTime  @db.Date
  uniqueViewers    Int       @default(0)
  totalImpressions Int       @default(0)
  likesCount       Int?
  commentsCount    Int?
  sharesCount      Int?
  audienceProfile  Bytes?    // MessagePack + Zstandard compressed
  
  creator          Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform, date])
  @@index([creatorId, platform])
  @@map("creator_reach")
}

model FeedSnapshot {
  id             String     @id @default(uuid())
  userId         String
  capturedAt     DateTime   @default(now())
  platform       String     @default("tiktok")
  itemCount      Int        @default(0)
  avgWatchTime   Float?
  sessionMetadata Bytes?    // MessagePack + Zstandard compressed
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItems     FeedItem[]
  ingestEvent   IngestEvent?

  @@index([userId])
  @@index([capturedAt])
  @@map("feed_snapshots")
}

model IngestEvent {
  id         String        @id @default(uuid())
  userId     String
  uploadId   String
  snapshotId String?       @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot   FeedSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([userId, uploadId])
  @@index([userId])
  @@map("ingest_events")
}

model FeedItem {
  id               String       @id @default(uuid())
  snapshotId       String
  videoId          String
  creatorId        String?
  creatorHandle    String?
  positionInFeed   Int
  caption          String?
  musicId          String?
  musicTitle       String?
  likesCount       Int?
  commentsCount    Int?
  sharesCount      Int?
  engagementMetrics Bytes?  // MessagePack + Zstandard compressed
  contentTags      String[]
  contentCategories String[]    // Detected categories for "why am I seeing this"
  watchDuration    Float?
  interacted       Boolean      @default(false)
  interactionType  String?
  
  snapshot         FeedSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([videoId])
  @@index([creatorHandle])
  @@index([likesCount])
  @@index([commentsCount])
  @@index([sharesCount])
  @@map("feed_items")
}

model ApiKey {
  id             String            @id @default(uuid())
  userId         String
  name           String
  accessPackage  AccessPackage
  lookupId       String            @unique
  keyPrefix      String
  keyHash        String            @unique
  status         ApiKeyStatus      @default(ACTIVE)
  scopes         String[]
  dailyQuota     Int               @default(500)
  monthlyQuota   Int               @default(10000)
  totalRequests  Int               @default(0)
  lastUsedAt     DateTime?
  lastUsedIp     String?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDaily     ApiKeyUsageDaily[]
  reportRuns     AgencyReportRun[]
  reportAuditEvents AgencyReportAuditEvent[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("api_keys")
}

model ApiKeyUsageDaily {
  id            String   @id @default(uuid())
  apiKeyId      String
  usageDate     DateTime @db.Date
  routeKey      String
  requestCount  Int      @default(0)
  successCount  Int      @default(0)
  errorCount    Int      @default(0)
  lastRequestAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apiKey        ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, usageDate, routeKey])
  @@index([apiKeyId, usageDate])
  @@map("api_key_usage_daily")
}

model AgencyReportPreset {
  id                    String           @id @default(uuid())
  userId                String
  name                  String
  reportType            AgencyReportType
  accessPackage         AccessPackage
  platform              String
  reportConfig          Json
  freshnessTier         String           @default("standard")
  allowedExportFormats  String[]
  lastRunAt             DateTime?
  archivedAt            DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportRuns            AgencyReportRun[]
  auditEvents           AgencyReportAuditEvent[]

  @@index([userId, archivedAt])
  @@index([reportType, platform])
  @@map("agency_report_presets")
}

model AgencyReportRun {
  id                    String           @id @default(uuid())
  presetId              String?
  userId                String
  apiKeyId              String?
  reportType            AgencyReportType
  accessPackage         AccessPackage
  platform              String
  reportTitle           String
  reportConfig          Json
  resultPayload         Json
  freshnessTier         String           @default("standard")
  availableExportFormats String[]
  watermarkKey          String?
  latestDataAt          DateTime?
  qualityGateStatus     String?
  generatedAt           DateTime         @default(now())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  preset                AgencyReportPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey                ApiKey?          @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  shares                AgencyReportShare[]
  auditEvents           AgencyReportAuditEvent[]

  @@index([userId, generatedAt])
  @@index([presetId, generatedAt])
  @@index([reportType, platform])
  @@map("agency_report_runs")
}

model AgencyReportShare {
  id                    String                 @id @default(uuid())
  reportRunId           String
  tokenHash             String                 @unique
  tokenPrefix           String
  status                AgencyReportShareStatus @default(ACTIVE)
  description           String?
  expiresAt             DateTime?
  lastAccessedAt        DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  revokedAt             DateTime?

  reportRun             AgencyReportRun        @relation(fields: [reportRunId], references: [id], onDelete: Cascade)
  auditEvents           AgencyReportAuditEvent[]

  @@index([reportRunId, status])
  @@map("agency_report_shares")
}

model AgencyReportAuditEvent {
  id                    String                  @id @default(uuid())
  eventType             AgencyReportAuditEventType
  presetId              String?
  reportRunId           String?
  reportShareId         String?
  userId                String?
  apiKeyId              String?
  metadata              Json?
  createdAt             DateTime                @default(now())

  preset                AgencyReportPreset?     @relation(fields: [presetId], references: [id], onDelete: SetNull)
  reportRun             AgencyReportRun?        @relation(fields: [reportRunId], references: [id], onDelete: SetNull)
  reportShare           AgencyReportShare?      @relation(fields: [reportShareId], references: [id], onDelete: SetNull)
  user                  User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey                ApiKey?                 @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([createdAt, eventType])
  @@index([reportRunId, createdAt])
  @@index([presetId, createdAt])
  @@map("agency_report_audit_events")
}
