{
    "name": "backend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "pretest": "bun run --filter @resma/shared build",
        "dev": "bun --watch run src/index.ts",
        "build": "tsc",
        "start": "bun run dist/index.js",
        "test": "bun test",
        "typecheck": "tsgo",
        "lint": "eslint src/",
        "db:migrate": "prisma migrate dev",
        "db:validate-platform-migration": "bun run src/scripts/validate-platform-account-migration.ts",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "openapi:write": "bun run src/scripts/write-openapi.ts"
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.0.0-beta2",
        "@prisma/client": "^5.8.0",
        "@resma/shared": "workspace:*",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "express-validator": "^7.0.1",
        "fzstd": "^0.1.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/bun": "^1.3.13",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.10.0",
        "@types/supertest": "^7.2.0",
        "eslint": "^8.56.0",
        "pino-pretty": "^13.1.3",
        "prisma": "^5.8.0",
        "supertest": "^7.2.2",
        "typescript": "^5.3.0",
        "vitest": "^4.1.5"
    }
}
