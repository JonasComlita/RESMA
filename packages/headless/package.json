{
  "name": "@resma/headless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "resma-headless": "./dist/cli.js"
  },
