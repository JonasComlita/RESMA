  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "capture": "bun run build && node dist/cli.js",
    "test": "bun test",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@resma/shared": "workspace:*",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  }
}
